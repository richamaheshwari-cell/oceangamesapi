PORT=3000
# Comma-separated origins (e.g. Vite app + Next.js admin)
CORS_ORIGIN=http://localhost:5173,http://localhost:3001
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DBNAME?schema=public"

# Auth (required for admin login/refresh)
ACCESS_TOKEN_SECRET=your_access_token_secret_min_32_chars
REFRESH_TOKEN_SECRET=your_refresh_token_secret_min_32_chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Password reset (admin forgot-password email)
PASSWORD_RESET_SECRET=your_password_reset_secret_min_32_chars
PASSWORD_RESET_TTL_HOURS=1
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
# Gmail: use App Password (Security > 2-Step Verification > App passwords), SMTP_HOST=smtp.gmail.com, PORT=587, SMTP_SECURE=false
# Test in dev: GET /api/v1/admin/auth/test-smtp returns exact error if send fails
RESET_PASSWORD_FROM_EMAIL=noreply@example.com
RESET_PASSWORD_LINK_BASE=http://localhost:5173
RESET_PASSWORD_SUBJECT=Reset your password
# Optional: RESET_PASSWORD_HTML (HTML body for reset email)

# Newsletter (subscribe/unsubscribe emails). Uses SMTP_* if NEWSLETTER_SMTP_* not set.
NEWSLETTER_FROM_EMAIL=newsletter@example.com
NEWSLETTER_SITE_URL=http://localhost:3001
# Production: NEWSLETTER_SITE_URL=https://theoceansgame.com (used for Visit / Unsubscribe links in emails)
NEWSLETTER_SMTP_HOST=
NEWSLETTER_SMTP_PORT=587
NEWSLETTER_SMTP_SECURE=false
NEWSLETTER_SMTP_USER=
NEWSLETTER_SMTP_PASS=
NEWSLETTER_SUBSCRIBED_SUBJECT=You're subscribed to our newsletter
NEWSLETTER_UNSUBSCRIBED_SUBJECT=You've unsubscribed
NEWSLETTER_NEWS_SUBJECT=New at Oceans Game: News & Updates

# Rate limiting and IP blocking (unusual traffic)
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_NEWSLETTER_MAX=10
RATE_LIMIT_NEWSLETTER_WINDOW_MS=900000
RATE_LIMIT_BLOCK_AFTER_FAILS=10
RATE_LIMIT_BLOCK_DURATION_MS=3600000
RATE_LIMIT_FAIL_WINDOW_MS=900000

# Scripts: createAdmin — creates super_admin (isSystem: true). Use for first admin in local + production.
BCRYPT_ROUNDS=12
ADMIN_EMAIL=aman.tiwari@triplew.in
ADMIN_PASSWORD=set_a_secure_password_in_env_only
ADMIN_NAME=Super Admin
