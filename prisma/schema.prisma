model SiteSetting {
  id              Int      @id @default(1)
  siteName        String   @default("TheOceanGames")
  logoUrl         String?
  faviconUrl      String?
  primaryColor    String?
  supportEmail    String?
  socials         Json?
  maintenanceMode Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("site_settings")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Page {
  id          String                   @id @default(uuid())
  slug        String                   @unique
  title       String
  contentHtml String
  seoTitle    String?
  seoDesc     String?
  isPublished Boolean                  @default(true)
  sortOrder   Int                      @default(0)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  createdById String?
  updatedById String?
  search_tsv  Unsupported("tsvector")? @default(dbgenerated("to_tsvector('english'::regconfig, ((COALESCE(title, ''::text) || ' '::text) || COALESCE(\"contentHtml\", ''::text)))"))
  createdBy   AdminUser?               @relation("PageCreatedBy", fields: [createdById], references: [id])
  updatedBy   AdminUser?               @relation("PageUpdatedBy", fields: [updatedById], references: [id])

  @@index([createdById])
  @@map("pages")
}

enum AdminRole {
  super_admin
  admin
  editor
  seo_editor
}

enum RoleHistoryAction {
  assigned
  role_updated
  revoked
}

enum PublishStatus {
  published
  draft
  pending
}
