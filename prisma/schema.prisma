/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model News {
  id                  String                   @id @default(uuid())
  title               String
  slug                String                   @unique
  featureImg          String?
  shortDesc           String
  publishDate         DateTime
  readTime            String
  content             Json?
  tags                String[]                 @default([])
  seoTitle            String?
  seoDesc             String?
  focusKeywords       String[]                 @default([])
  isTrending          Boolean                  @default(false)
  status              PublishStatus            @default(draft)
  createdById         String?
  updatedById         String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  search_tsv          Unsupported("tsvector")? @default(dbgenerated("to_tsvector('english'::regconfig, ((((COALESCE(title, ''::text) || ' '::text) || COALESCE(\"shortDesc\", ''::text)) || ' '::text) || COALESCE((content)::text, ''::text)))"))
  showInBlog          Boolean?                 @default(false)
  showInGameArticle   Boolean?                 @default(false)
  showInBonusArticle  Boolean?                 @default(false)
  showInCasinoArticle Boolean?                 @default(false)
  showInNews          Boolean?                 @default(true)
  createdBy           AdminUser?               @relation("NewsCreatedBy", fields: [createdById], references: [id])
  updatedBy           AdminUser?               @relation("NewsUpdatedBy", fields: [updatedById], references: [id])

  @@index([status])
  @@index([publishDate])
  @@index([createdById])
  @@index([isTrending])
